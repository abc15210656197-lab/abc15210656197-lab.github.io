# VITE_GEMINI_API_KEY: Public browser key for Gemini AI calls.
# Do not put a private server-side GEMINI_API_KEY in frontend builds.
VITE_GEMINI_API_KEY="MY_PUBLIC_BROWSER_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
